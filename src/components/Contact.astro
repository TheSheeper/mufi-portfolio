---
import { Image } from "astro:assets"
import {Mail, MapPin} from "@lucide/astro"
import { Icon } from 'astro-icon/components'
import Icon01 from "../assets/images/icon_01.jpg"

const socialLinks = [
  { href: "https://www.instagram.com/mufikingdom/", label: "Instagram", iconName: "instagram" },
  { href: "https://www.facebook.com/mufikingdom", label: "Facebook", iconName: "facebook" },
]
---

<section id="contact" class="py-16 sm:py-20 md:py-24 px-4 sm:px-6 relative">
      {/* Decorative star */}
      <div class="absolute top-12 right-4 sm:right-20 w-12 sm:w-16 h-12 sm:h-16 hidden md:block">
        <Image 
          src={Icon01}
          alt=""
          class="rounded-xl"
        />
      </div>

      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <div class="space-y-6 sm:space-y-8 text-center lg:text-left">
            <div>
              <h2 class="font-serif text-2xl sm:text-3xl font-medium text-foreground mb-4">
                Let&apos;s Create Together
              </h2>
              <div class="w-12 h-1 bg-primary rounded-full mx-auto lg:mx-0" />
            </div>

            <p class="text-base sm:text-lg text-muted-foreground leading-relaxed max-w-md mx-auto lg:mx-0">
              Have a project in mind? I&apos;d love to bring your ideas to life with 
              colorful illustrations and playful designs. Let&apos;s make something 
              amazing together!
            </p>

            <div class="space-y-3 sm:space-y-4 inline-flex flex-col items-center lg:items-start">
              <div class="flex items-center gap-3 sm:gap-4">
                <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-primary/10 flex items-center justify-center">
                  <Mail class="w-4 h-4 sm:w-5 sm:h-5 text-primary" />
                </div>
                <div class="text-left">
                  <p class="text-xs sm:text-sm text-muted-foreground">Email</p>
                  <a
                    href="mailto:hello@mufi.art"
                    class="text-sm sm:text-base text-foreground hover:text-primary transition-colors font-medium"
                  >
                    hello@mufi.art
                  </a>
                </div>
              </div>

              <div class="flex items-center gap-3 sm:gap-4">
                <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-accent/10 flex items-center justify-center">
                  <MapPin class="w-4 h-4 sm:w-5 sm:h-5 text-accent" />
                </div>
                <div class="text-left">
                  <p class="text-xs sm:text-sm text-muted-foreground">Location</p>
                  <p class="text-sm sm:text-base text-foreground font-medium">Working Worldwide</p>
                </div>
              </div>
            </div>

            <div class="flex items-center justify-center lg:justify-start gap-3 sm:gap-4 pt-2 sm:pt-4">
              {socialLinks.map((social) => (
                <a
                  href={social.href}
                  target="_blank"
                  class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-primary/10 flex items-center justify-center hover:bg-primary/20 transition-colors"
                  aria-label={social.label}
                >
                  <Icon name={social.iconName} class="w-4 h-4 sm:w-5 sm:h-5 text-primary" />
                </a>
              ))}
            </div>
          </div>

          <div class="bg-card p-5 sm:p-6 md:p-8 rounded-xl sm:rounded-2xl border border-border shadow-sm">
            <form class="space-y-4 sm:space-y-6">
              <div class="space-y-1.5 sm:space-y-2">
                <label for="name" class="text-xs sm:text-sm font-medium text-foreground">
                  Name
                </label>
                <input
                  type="text"
                  id="name"
                  class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-background border border-input rounded-lg sm:rounded-xl text-sm sm:text-base text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                  placeholder="Your name"
                />
              </div>

              <div class="space-y-1.5 sm:space-y-2">
                <label for="email" class="text-xs sm:text-sm font-medium text-foreground">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-background border border-input rounded-lg sm:rounded-xl text-sm sm:text-base text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                  placeholder="your@email.com"
                />
              </div>

              <div class="space-y-1.5 sm:space-y-2">
                <label for="message" class="text-xs sm:text-sm font-medium text-foreground">
                  Message
                </label>
                <textarea
                  id="message"
                  rows={4}
                  class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-background border border-input rounded-lg sm:rounded-xl text-sm sm:text-base text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors resize-none"
                  placeholder="Tell me about your project..."
                />
              </div>

              <button type="submit" class="w-full rounded-lg sm:rounded-xl py-5 sm:py-6 text-sm sm:text-base font-medium">
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>