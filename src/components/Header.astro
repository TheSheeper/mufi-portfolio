---
import { Image } from "astro:assets";
import MufiLogo from "../assets/Logo.png";
import {Icon} from "astro-icon/components"

const navLinks = [
    { href: "/mufi-portfolio#about", label: "About" },
    { href: "/mufi-portfolio#education", label: "Education" },
    { href: "/mufi-portfolio#achievements", label: "Achievements" },
    { href: "/mufi-portfolio#portfolio", label: "Portfolio" },
    { href: "/mufi-portfolio#contact", label: "Contact" },
];
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border"
>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-2.5 sm:py-3">
        <div class="flex items-center justify-between">
            <a href="/mufi-portfolio" class="flex items-center gap-2">
                <Image
                    src={MufiLogo}
                    alt="Mufi"
                    class="h-8 sm:h-10 w-auto"
                />
                <span
                    class="font-serif text-lg sm:text-xl font-semibold text-foreground"
                    >Mufi</span
                >
            </a>

            {/* Desktop Navigation */}
            <nav class="hidden md:flex items-center gap-6 lg:gap-8">
                {
                    navLinks.map((link) => (
                        <a
                            href={link.href}
                            class="text-sm text-muted-foreground hover:text-primary transition-colors"
                        >
                            {link.label}
                        </a>
                    ))
                }
            </nav>

            <!-- {/* Mobile Menu Button */}
          <button
            variant="ghost"
            size="icon"
            class="md:hidden h-9 w-9"
            onClick={() => setIsOpen(!isOpen)}
            aria-label={isOpen ? "Close menu" : "Open menu"}
          >
            {isOpen ? <X class="h-5 w-5" /> : <Menu class="h-5 w-5" />}
          </button>
        </div>

        {/* Mobile Navigation */}
        {isOpen && (
          <nav class="md:hidden pt-4 pb-3 flex flex-col gap-1">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class="text-sm text-muted-foreground hover:text-primary hover:bg-primary/5 transition-colors py-2.5 px-3 rounded-lg"
                onClick={() => setIsOpen(false)}
              >
                {link.label}
              </a>
            ))}
          </nav>
        )} -->
        </div>
    </div>
</header>
