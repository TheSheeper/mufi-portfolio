---
import { Image } from "astro:assets"
import MufiLogo from "../assets/Logo.png"

---

<footer
    class="py-6 sm:py-8 px-4 sm:px-6 border-t border-border bg-secondary/30"
>
    <div class="max-w-6xl mx-auto">
        <div
            class="flex flex-col items-center gap-4 sm:gap-6 md:flex-row md:justify-between"
        >
            <a href="/" class="flex items-center gap-2">
                <Image
                    src={MufiLogo}
                    alt="Mufi"
                    class="h-7 sm:h-8 w-auto"
                />
                <span
                    class="font-serif text-base sm:text-lg font-medium text-foreground"
                    >Mufi</span
                >
            </a>

            <p
                class="text-xs sm:text-sm text-muted-foreground text-center order-3 md:order-2"
            >
                &copy; 2026 Mufi - Arte e Ilustracion
            </p>

            <p
                class="text-xs sm:text-sm text-muted-foreground order-2 md:order-3"
            >
                Designed with love
            </p>
        </div>
    </div>
</footer>
